# groups.ttl — sh:PropertyGroup definitions for research board shapes
#
# Property groups define the section headers used in template generation.
# Each group has an rdfs:label that becomes the ## heading when
# nk templates generates a body template.
#
# Shared group: kb:TurtleBlockGroup — used by hypothesis, experiment, paper,
# measure, and literature (5 of 6 research types).

@prefix kb:   <https://nusy.dev/kanban/> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# ---------------------------------------------------------------------------
# Shared: Turtle Block group (used by 5 of 6 research types)
# ---------------------------------------------------------------------------

kb:TurtleBlockGroup a sh:PropertyGroup ;
    rdfs:label "Turtle Block" ;
    sh:order 99 ;
    rdfs:comment "Turtle RDF block — required for graph queries. See type-specific TurtleBlockShape for required predicates." .

# ---------------------------------------------------------------------------
# Hypothesis groups
# ---------------------------------------------------------------------------

kb:ClaimGroup a sh:PropertyGroup ;
    rdfs:label "Claim" ;
    sh:order 1 .

kb:RationaleGroup a sh:PropertyGroup ;
    rdfs:label "Rationale" ;
    sh:order 2 .

kb:VariablesGroup a sh:PropertyGroup ;
    rdfs:label "Variables" ;
    sh:order 3 .

kb:ExperimentLinkGroup a sh:PropertyGroup ;
    rdfs:label "Experiments" ;
    sh:order 4 .

kb:FalsifiableGroup a sh:PropertyGroup ;
    rdfs:label "Falsifiable By" ;
    sh:order 5 .

kb:ACFConnectionGroup a sh:PropertyGroup ;
    rdfs:label "ACF Connection" ;
    sh:order 6 .

