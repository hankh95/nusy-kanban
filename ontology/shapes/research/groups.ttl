kb:AbstractGroup a sh:PropertyGroup ;
    rdfs:label "Abstract" ;
    sh:order 1 .

kb:HypothesesTestedGroup a sh:PropertyGroup ;
    rdfs:label "Hypotheses Tested" ;
    sh:order 2 .

kb:KeyExperimentsGroup a sh:PropertyGroup ;
    rdfs:label "Key Experiments" ;
    sh:order 3 .

kb:OutlineGroup a sh:PropertyGroup ;
    rdfs:label "Outline" ;
    sh:order 4 .

kb:SubmissionTargetGroup a sh:PropertyGroup ;
    rdfs:label "Submission Target" ;
    sh:order 5 .

# ---------------------------------------------------------------------------
