    sh:order 5 .

kb:AnalysisPlanGroup a sh:PropertyGroup ;
    rdfs:label "Analysis Plan" ;
    sh:order 6 .

kb:ExpectedResultsGroup a sh:PropertyGroup ;
    rdfs:label "Expected Results" ;
    sh:order 7 .

kb:DataLocationGroup a sh:PropertyGroup ;
    rdfs:label "Data Location" ;
    sh:order 9 .

# ---------------------------------------------------------------------------
