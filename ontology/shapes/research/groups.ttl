kb:PurposeGroup a sh:PropertyGroup ;
    rdfs:label "Purpose" ;
    sh:order 1 .

kb:MethodParticipantsGroup a sh:PropertyGroup ;
    rdfs:label "Method — Participants" ;
    sh:order 2 .

kb:MethodMaterialsGroup a sh:PropertyGroup ;
    rdfs:label "Method — Materials" ;
    sh:order 3 .

kb:MethodProcedureGroup a sh:PropertyGroup ;
    rdfs:label "Method — Procedure" ;
