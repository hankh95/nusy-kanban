kb:DescriptionGroup a sh:PropertyGroup ;
    rdfs:label "Description" ;
    sh:order 1 .

kb:SpecificationGroup a sh:PropertyGroup ;
    rdfs:label "Specification" ;
    sh:order 2 .

kb:HistoricalValuesGroup a sh:PropertyGroup ;
    rdfs:label "Historical Values" ;
    sh:order 3 .

